{
    "version": 2,
    "outputDirectory": "public",
    "functions": {
        "api/index.php": { "runtime": "vercel-php@8.2" }
    },
    "routes": [
        {
            "src": "/(css|js|images|fonts|build)/(.*)",
            "dest": "public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}