APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=veggie
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_DRIVER=file
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# PayPal Setting & API Credentials
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# VietQR Bank Transfer
VIETQR_BANK_BIN=970415
VIETQR_ACCOUNT_NUMBER=your_bank_account_number
VIETQR_ACCOUNT_NAME="MEALKIT"
VIETQR_TEMPLATE=compact2
VIETQR_IMAGE_BASE_URL=https://img.vietqr.io/image

# API Keys Gemini
GOOGLE_GEMINI_API_KEY=your_gemini_api_key

# Google Maps Delivery
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_MAPS_BROWSER_KEY="${GOOGLE_MAPS_API_KEY}"
GOOGLE_MAPS_SERVER_KEY="${GOOGLE_MAPS_API_KEY}"
STORE_LATITUDE=20.918601
STORE_LONGITUDE=105.762511
MAX_DELIVERY_DISTANCE_KM=40
DELIVERY_BASE_FEE=10000
DELIVERY_BASE_DISTANCE_KM=3
DELIVERY_PER_KM_FEE=5000
DELIVERY_FALLBACK_ROAD_MULTIPLIER=1.3
